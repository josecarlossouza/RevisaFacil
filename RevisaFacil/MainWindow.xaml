<!-- MainWindow.xaml — v1.3.0 -->
<!-- ALTERAÇÕES:
     1. Title atualizado para "RevisaFácil - Gerenciador de Estudos - v1.3.0"
     2. Botão "Meus Assuntos" renomeado para "Minhas Revisões"
     3. Botão "❓ Ajuda" movido para o final do rodapé (após Exportar e Importar)
-->
<Window x:Class="RevisaFacil.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RevisaFácil - Gerenciador de Estudos - v1.3.0"
        Height="680" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Menu lateral ── -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel LastChildFill="False">

                <!-- Topo: logo + temas + navegação -->
                <StackPanel DockPanel.Dock="Top" Margin="10">
                    <TextBlock Text="MEUS ESTUDOS" Foreground="White" FontSize="18"
                               HorizontalAlignment="Center" Margin="0,20,0,10" FontWeight="Bold"/>

                    <TextBlock Text="Tema Atual:" Foreground="#BDC3C7" FontSize="11" Margin="5,0"/>
                    <ComboBox x:Name="cbTemas" Height="30" Margin="5,5,5,0"
                              SelectionChanged="cbTemas_SelectionChanged"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,20">
                        <Button Content="➕ Novo Tema" Click="btnNovoTema_Click" Width="95" Height="25"
                                Margin="2" Background="#27AE60" Foreground="White" BorderThickness="0" FontSize="10"/>
                        <Button Content="🗑 Excluir" Click="btnExcluirTema_Click" Width="95" Height="25"
                                Margin="2" Background="#C0392B" Foreground="White" BorderThickness="0" FontSize="10"/>
                    </StackPanel>

                    <!-- Navegação principal -->
                    <Button x:Name="btnPainel"
                            Content="🏠 Painel"
                            Click="btnPainel_Click"
                            Height="40" Margin="5"
                            Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                    <!-- RENOMEADO: Meus Assuntos → Minhas Revisões -->
                    <Button x:Name="btnAssuntos"
                            Content="📚 Minhas Revisões"
                            Click="btnAssuntos_Click"
                            Height="40" Margin="5"
                            Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                    <Button x:Name="btnCalendario"
                            Content="📅 Calendário"
                            Click="NavCalendario_Click"
                            Height="40" Margin="5"
                            Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                    <Button x:Name="btnEstatisticas"
                            Content="📊 Estatísticas"
                            Click="btnEstatisticas_Click"
                            Height="40" Margin="5"
                            Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                    <Separator Background="#5D6D7E" Margin="10,20"/>

                    <Button x:Name="btnNovaDisciplina"
                            Content="➕ Nova Disciplina"
                            Click="btnNovaDisciplina_Click"
                            Height="40" Margin="5"
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                    <Button x:Name="btnNovoAssunto"
                            Content="➕ Novo Assunto"
                            Click="btnNovoAssunto_Click"
                            Height="45" Margin="5"
                            Background="#2980B9" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <!-- Rodapé: Exportar + Importar + Ajuda (por último) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,15">
                    <Separator Background="#5D6D7E" Margin="0,0,0,8"/>

                    <Button x:Name="btnExportar"
                            Content="📤 Exportar Excel"
                            Click="btnExportar_Click"
                            Height="38" Margin="0,0,0,6"
                            Background="#8E44AD" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            ToolTip="Exporta todos os assuntos do tema atual para um arquivo .xlsx"/>

                    <Button x:Name="btnImportar"
                            Content="📥 Importar Excel"
                            Click="btnImportar_Click"
                            Height="38" Margin="0,0,0,8"
                            Background="#D35400" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            ToolTip="Importa assuntos de um arquivo .xlsx exportado pelo RevisaFácil"/>

                    <!-- Botão Ajuda — agora por último -->
                    <Button x:Name="btnAjuda"
                            Content="❓ Ajuda"
                            Click="btnAjuda_Click"
                            Height="34"
                            Background="#5D6D7E" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="12"
                            ToolTip="Como usar, novidades e informações sobre o RevisaFácil">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="📖 Como Usar o App"   Click="AjudaComoUsar_Click"/>
                                <MenuItem Header="🆕 Novidades (v1.3.0)" Click="AjudaNovidades_Click"/>
                                <MenuItem Header="ℹ️ Sobre"              Click="AjudaSobre_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Área de conteúdo principal -->
        <Grid Grid.Column="1" Background="#ECF0F1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
