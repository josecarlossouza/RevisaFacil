<Window x:Class="RevisaFacil.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RevisaFacil - Gerenciador de Estudos" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10">
                <TextBlock Text="MEUS ESTUDOS" Foreground="White" FontSize="18" 
                           HorizontalAlignment="Center" Margin="0,20,0,10" FontWeight="Bold"/>

                <TextBlock Text="Tema Atual:" Foreground="#BDC3C7" FontSize="11" Margin="5,0"/>
                <ComboBox x:Name="cbTemas" Height="30" Margin="5,5,5,0" SelectionChanged="cbTemas_SelectionChanged"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,20">
                    <Button Content="➕ Novo Tema" Click="btnNovoTema_Click" Width="95" Height="25" Margin="2" Background="#27AE60" Foreground="White" BorderThickness="0" FontSize="10"/>
                    <Button Content="🗑 Excluir" Click="btnExcluirTema_Click" Width="95" Height="25" Margin="2" Background="#C0392B" Foreground="White" BorderThickness="0" FontSize="10"/>
                </StackPanel>

                <Button x:Name="btnPainel" Content="🏠 Painel" Click="btnPainel_Click" Height="40" Margin="5" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnAssuntos" Content="📚 Meus Assuntos" Click="btnAssuntos_Click" Height="40" Margin="5" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="btnCalendario" Content="📅 Calendário" Click="NavCalendario_Click" Height="40" Margin="5" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <Separator Background="#5D6D7E" Margin="10,20"/>

                <Button x:Name="btnNovaDisciplina" Content="➕ Nova Disciplina" Click="btnNovaDisciplina_Click" Height="40" Margin="5" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnNovoAssunto" Content="➕ Novo Assunto" Click="btnNovoAssunto_Click" Height="45" Margin="5" Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#ECF0F1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>