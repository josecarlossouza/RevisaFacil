<Page x:Class="RevisaFacil.Views.AssuntosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:RevisaFacil.Helpers"
      Title="Assuntos" Background="#F0F3F4">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📅 MINHAS REVISÕES" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Buscar Assunto:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtBuscaAssunto" Width="200" TextChanged="Filtro_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Disciplina:" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbFiltroDisciplina" Width="180" DisplayMemberPath="Nome" SelectedValuePath="Id" SelectionChanged="Filtro_Changed"/>
                </StackPanel>
                <Button Content="Limpar Filtros" Click="LimparFiltros_Click" VerticalAlignment="Bottom" Height="26" Padding="10,0" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="dgAssuntos" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" CellEditEnding="dgAssuntos_CellEditEnding">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick" />

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDestacado}" Value="True">
                            <Setter Property="Background" Value="#D4EFDF"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDestacado}" Value="False">
                            <Setter Property="Background" Value="White"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Disciplina" Binding="{Binding Disciplina.Nome}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Assunto" Binding="{Binding Titulo}" Width="*" IsReadOnly="True"/>

                <DataGridTextColumn Header="Início" Binding="{Binding DataInicio, StringFormat=\{0:dd/MM/yyyy\}, UpdateSourceTrigger=PropertyChanged}" Width="100"/>

                <DataGridTemplateColumn Width="105">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="R1 (" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtR1" Tag="1" Width="25" KeyDown="Intervalo_KeyDown" LostFocus="Intervalo_LostFocus" BorderThickness="0,0,0,1" HorizontalContentAlignment="Center" Background="Transparent"/>
                            <TextBlock Text="d)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataRev1, StringFormat=\{0:dd/MM/yyyy\}}" Background="{Binding Rev1Concluida, Converter={StaticResource StatusToColorConverter}}" Foreground="White" Click="MarcarRevisao_Click" Tag="1" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="105">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="R2 (" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtR2" Tag="2" Width="25" KeyDown="Intervalo_KeyDown" LostFocus="Intervalo_LostFocus" BorderThickness="0,0,0,1" HorizontalContentAlignment="Center" Background="Transparent"/>
                            <TextBlock Text="d)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataRev2, StringFormat=\{0:dd/MM/yyyy\}}" Background="{Binding Rev2Concluida, Converter={StaticResource StatusToColorConverter}}" Foreground="White" Click="MarcarRevisao_Click" Tag="2" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="105">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="R3 (" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtR3" Tag="3" Width="25" KeyDown="Intervalo_KeyDown" LostFocus="Intervalo_LostFocus" BorderThickness="0,0,0,1" HorizontalContentAlignment="Center" Background="Transparent"/>
                            <TextBlock Text="d)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataRev3, StringFormat=\{0:dd/MM/yyyy\}}" Background="{Binding Rev3Concluida, Converter={StaticResource StatusToColorConverter}}" Foreground="White" Click="MarcarRevisao_Click" Tag="3" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="105">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="R4 (" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtR4" Tag="4" Width="25" KeyDown="Intervalo_KeyDown" LostFocus="Intervalo_LostFocus" BorderThickness="0,0,0,1" HorizontalContentAlignment="Center" Background="Transparent"/>
                            <TextBlock Text="d)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataRev4, StringFormat=\{0:dd/MM/yyyy\}}" Background="{Binding Rev4Concluida, Converter={StaticResource StatusToColorConverter}}" Foreground="White" Click="MarcarRevisao_Click" Tag="4" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="105">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="R5 (" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtR5" Tag="5" Width="25" KeyDown="Intervalo_KeyDown" LostFocus="Intervalo_LostFocus" BorderThickness="0,0,0,1" HorizontalContentAlignment="Center" Background="Transparent"/>
                            <TextBlock Text="d)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataRev5, StringFormat=\{0:dd/MM/yyyy\}}" Background="{Binding Rev5Concluida, Converter={StaticResource StatusToColorConverter}}" Foreground="White" Click="MarcarRevisao_Click" Tag="5" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑" Click="btnApagarAssunto_Click" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>