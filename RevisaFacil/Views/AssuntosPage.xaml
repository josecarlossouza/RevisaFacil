<!-- AssuntosPage.xaml -->
<Page x:Class="RevisaFacil.Views.AssuntosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:RevisaFacil.Helpers"
      Title="Assuntos" Background="#F0F3F4">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="📅 MINHAS REVISÕES" FontSize="24" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Filtros -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Buscar Assunto:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtBuscaAssunto" Width="200" TextChanged="Filtro_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Disciplina:" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbFiltroDisciplina" Width="180" DisplayMemberPath="Nome"
                              SelectedValuePath="Id" SelectionChanged="Filtro_Changed"/>
                </StackPanel>
                <Button Content="Limpar Filtros" Click="LimparFiltros_Click" VerticalAlignment="Bottom"
                        Height="26" Padding="10,0" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Controle de quantidade de revisões -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Quantidade de revisões:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#34495E"/>
                <Button Content="－" x:Name="btnMenosRevisoes" Click="btnMenosRevisoes_Click"
                        Width="30" Height="30" FontSize="16" FontWeight="Bold"
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Border Background="#F0F3F4" CornerRadius="4" Padding="12,5" Margin="5,0">
                    <TextBlock x:Name="txtQtdRevisoes" Text="10" FontSize="16" FontWeight="Bold"
                               Foreground="#2C3E50" VerticalAlignment="Center" MinWidth="20"
                               HorizontalAlignment="Center"/>
                </Border>
                <Button Content="＋" x:Name="btnMaisRevisoes" Click="btnMaisRevisoes_Click"
                        Width="30" Height="30" FontSize="16" FontWeight="Bold"
                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="(mín: 1 | máx: 30)" Foreground="#95A5A6" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid com scroll horizontal -->
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="dgAssuntos" AutoGenerateColumns="False" CanUserAddRows="False"
                      Background="White" CellEditEnding="dgAssuntos_CellEditEnding"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDestacado}" Value="True">
                                <Setter Property="Background" Value="#D4EFDF"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDestacado}" Value="False">
                                <Setter Property="Background" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- Colunas fixas -->
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Disciplina" Binding="{Binding Disciplina.Nome}"
                                        Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Assunto" Binding="{Binding Titulo}"
                                        Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Início"
                                        Binding="{Binding DataInicio, StringFormat=\{0:dd/MM/yyyy\}, UpdateSourceTrigger=PropertyChanged}"
                                        Width="100"/>
                    <!-- As colunas de revisão são adicionadas dinamicamente no code-behind -->
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>
