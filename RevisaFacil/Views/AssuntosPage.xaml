<!-- AssuntosPage.xaml — v1.3.2
     CORREÇÃO DEFINITIVA da edição de data de início:
     
     A coluna "Início" agora é IsReadOnly="True" — ela NUNCA entra em modo de
     edição nativo do DataGrid (que era a raiz de todos os conflitos anteriores).
     
     Ao dar duplo clique na célula "Início", o code-behind abre um pequeno Popup
     flutuante com um DatePicker já com o calendário aberto. O usuário escolhe a
     data e o Popup fecha sozinho, salvando no banco.
     
     Isso elimina:
       - O problema do CellEditingTemplate não ativar
       - O crash "Refresh não é permitido durante AddNew/EditItem"
       - A necessidade de BeginEdit/CommitEdit/CancelEdit
-->
<Page x:Class="RevisaFacil.Views.AssuntosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:RevisaFacil.Helpers"
      Title="Assuntos" Background="#F0F3F4">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título com nome da disciplina atual -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="📅 REVISÕES — " FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtTituloDisciplina" Text="..." FontSize="22" FontWeight="Bold"
                       Foreground="#27AE60" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Seletor de Disciplina + Busca de Assunto -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="📚 Disciplina:" FontWeight="SemiBold" Foreground="#34495E"/>
                    <ComboBox x:Name="cbDisciplina" Width="220" DisplayMemberPath="Nome"
                              SelectedValuePath="Id" SelectionChanged="CbDisciplina_SelectionChanged"
                              FontSize="13"/>
                </StackPanel>
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="🔍 Buscar Assunto:" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBox x:Name="txtBuscaAssunto" Width="200" TextChanged="BuscaAssunto_Changed"
                             FontSize="13"/>
                </StackPanel>
                <Button Content="↺ Limpar Busca" Click="LimparBusca_Click" VerticalAlignment="Bottom"
                        Height="28" Padding="12,0" Background="#95A5A6" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Controle de quantidade de revisões (por disciplina) -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Revisões desta disciplina:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#34495E"/>
                <Button Content="－" x:Name="btnMenosRevisoes" Click="BtnMenosRevisoes_Click"
                        Width="30" Height="30" FontSize="16" FontWeight="Bold"
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Border Background="#F0F3F4" CornerRadius="4" Padding="12,5" Margin="5,0">
                    <TextBlock x:Name="txtQtdRevisoes" Text="10" FontSize="16" FontWeight="Bold"
                               Foreground="#2C3E50" VerticalAlignment="Center" MinWidth="20"
                               HorizontalAlignment="Center"/>
                </Border>
                <Button Content="＋" x:Name="btnMaisRevisoes" Click="BtnMaisRevisoes_Click"
                        Width="30" Height="30" FontSize="16" FontWeight="Bold"
                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="(mín: 1 | máx: 30)" Foreground="#95A5A6" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBlock Text=" — Cabeçalhos de dias afetam SOMENTE esta disciplina"
                           Foreground="#7F8C8D" FontSize="11" FontStyle="Italic"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Popup flutuante para edição de data de início.
             Aberto programaticamente pelo duplo clique na coluna "Início".
             StaysOpen="False" faz o Popup fechar ao clicar fora. -->
        <Popup x:Name="popupDataInicio"
               StaysOpen="False"
               AllowsTransparency="True"
               Placement="Mouse"
               PopupAnimation="Fade"
               Closed="PopupDataInicio_Closed">
            <Border Background="White" BorderBrush="#D5DBDB" BorderThickness="1"
                    CornerRadius="6" Padding="8"
                    Effect="{x:Null}">
                <StackPanel>
                    <TextBlock x:Name="txtPopupLabel" Text="Selecione a nova data de início:"
                               FontSize="12" Foreground="#34495E" Margin="0,0,0,6"/>
                    <DatePicker x:Name="dpPopup"
                                Language="pt-BR"
                                FontSize="13"
                                IsDropDownOpen="True"
                                SelectedDateChanged="DpPopup_SelectedDateChanged"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- DataGrid com scroll horizontal -->
        <ScrollViewer Grid.Row="4" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="dgAssuntos" AutoGenerateColumns="False" CanUserAddRows="False"
                      Background="White" HorizontalScrollBarVisibility="Auto"
                      IsReadOnly="True">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDestacado}" Value="True">
                                <Setter Property="Background" Value="#D4EFDF"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDestacado}" Value="False">
                                <Setter Property="Background" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!-- Coluna Assunto: duplo clique alterna IsDestacado -->
                    <DataGridTextColumn Header="Assunto" Binding="{Binding Titulo}"
                                        Width="220" IsReadOnly="True"/>

                    <!-- Coluna Início: duplo clique abre o Popup com DatePicker.
                         Tooltip orienta o usuário. -->
                    <DataGridTemplateColumn Header="Início" Width="130" SortMemberPath="DataInicio"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DataInicio, StringFormat=\{0:dd/MM/yyyy\}}"
                                           VerticalAlignment="Center" Margin="4,0"
                                           FontSize="13"
                                           ToolTip="Duplo clique para alterar a data de início"
                                           Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Colunas de revisão geradas dinamicamente no code-behind -->
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>
