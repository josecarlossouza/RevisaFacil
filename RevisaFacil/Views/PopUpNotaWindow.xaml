<Window x:Class="RevisaFacil.Views.PopUpNotaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anotação do Dia" Height="350" Width="450" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F7F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTituloData" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <TextBox x:Name="txtNotaPopUp" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" 
                 FontSize="14" Padding="10" BorderThickness="1" BorderBrush="#D5DBDB"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Click="btnCancelar_Click" Width="100" Height="35" Margin="0,0,10,0" Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="Salvar" Click="btnSalvar_Click" Width="100" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>