<Page x:Class="RevisaFacil.Views.CalendarioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:RevisaFacil.Helpers"
      Title="Calendário Visual de Revisões" Background="#F0F3F4">

    <Page.Resources>
        <helpers:DataTemNotaParaCorConverter x:Key="DataTemNotaCorConv"/>
        <helpers:DiaParaThicknessConverter x:Key="DiaThicknessConv"/>
        <helpers:DiaParaCorBordaConverter x:Key="DiaCorBordaConv"/>

        <Style x:Key="DiaSemanaLabelStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Calendário visual de revisões" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" DockPanel.Dock="Left" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,20,0">
                <Button Content="◀ Mês anterior" Click="btnMesAnterior_Click" Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>

                <Border Background="#34495E" CornerRadius="4" Padding="15,5" Margin="5,0">
                    <TextBlock x:Name="txtMesAno" Text="ABRIL DE 2026" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </Border>

                <Button Content="Próximo mês ▶" Click="btnProximoMes_Click" Style="{StaticResource NavButtonStyle}" Margin="5,0,0,0"/>
            </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="7">
            <TextBlock Text="Dom" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Seg" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Ter" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Qua" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Qui" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Sex" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Sáb" Style="{StaticResource DiaSemanaLabelStyle}"/>
        </UniformGrid>

        <ItemsControl Grid.Row="2" x:Name="icDiasCalendario">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" Background="Transparent"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" CornerRadius="8" Cursor="Hand"
                            MouseDown="BorderDia_MouseDown"
                            Tag="{Binding}" 
                            BorderBrush="{Binding Converter={StaticResource DiaCorBordaConv}}"
                            BorderThickness="{Binding Converter={StaticResource DiaThicknessConv}}">
                        <Border.Background>
                            <MultiBinding Converter="{StaticResource DataTemNotaCorConv}">
                                <Binding Path="." />
                                <Binding Path="DataContext.DatasComNotas" RelativeSource="{RelativeSource AncestorType=Page}" />
                            </MultiBinding>
                        </Border.Background>

                        <Grid>
                            <TextBlock Text="{Binding StringFormat=dd}" FontWeight="Bold" FontSize="14" Margin="10" 
                                       HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>