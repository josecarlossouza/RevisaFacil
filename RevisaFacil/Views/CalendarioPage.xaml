<!-- CalendarioPage.xaml -->
<Page x:Class="RevisaFacil.Views.CalendarioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:RevisaFacil.Helpers"
      Title="Calendário Visual de Revisões" Background="#F0F3F4">

    <Page.Resources>
        <helpers:DataTemNotaParaCorConverter x:Key="DataTemNotaCorConv"/>
        <helpers:DiaParaThicknessConverter   x:Key="DiaThicknessConv"/>
        <helpers:DiaParaCorBordaConverter    x:Key="DiaCorBordaConv"/>

        <Style x:Key="DiaSemanaLabelStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ViewButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#34495E"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho: título + navegação -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Calendário visual de revisões" FontSize="24" FontWeight="Bold"
                       Foreground="#2C3E50" DockPanel.Dock="Left" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                        HorizontalAlignment="Right" Margin="0,0,0,0">
                <Button Content="◀ Anterior" Click="btnAnterior_Click"
                        Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                <Border Background="#34495E" CornerRadius="4" Padding="15,5" Margin="5,0">
                    <TextBlock x:Name="txtMesAno" Text="ABRIL DE 2026" FontSize="14"
                               FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </Border>
                <Button Content="Próximo ▶" Click="btnProximo_Click"
                        Style="{StaticResource NavButtonStyle}" Margin="5,0,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Seletor de visualização -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Visualizar:" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="#34495E" Margin="0,0,10,0"/>
            <Button x:Name="btnViewMes"    Content="📅 Mês inteiro"   Click="btnViewMes_Click"
                    Style="{StaticResource ViewButtonStyle}" Margin="0,0,5,0"/>
            <Button x:Name="btnViewSemana" Content="📆 Semana atual"  Click="btnViewSemana_Click"
                    Style="{StaticResource ViewButtonStyle}" Margin="0,0,5,0"/>
            <Button x:Name="btnViewDia"    Content="☀️ Dia atual"      Click="btnViewDia_Click"
                    Style="{StaticResource ViewButtonStyle}"/>
        </StackPanel>

        <!-- Cabeçalho dias da semana (oculto no modo Dia) -->
        <UniformGrid x:Name="gridDiasSemana" Grid.Row="2" Columns="7">
            <TextBlock Text="Dom" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Seg" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Ter" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Qua" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Qui" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Sex" Style="{StaticResource DiaSemanaLabelStyle}"/>
            <TextBlock Text="Sáb" Style="{StaticResource DiaSemanaLabelStyle}"/>
        </UniformGrid>

        <!-- Grade de cards -->
        <ItemsControl Grid.Row="3" x:Name="icDiasCalendario">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" Background="Transparent"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!--
                        Tag = o próprio item (DiaCalendarioItem) — o code-behind extrai a data dele.
                        Os converters recebem o item inteiro e extraem a propriedade Data internamente.
                    -->
                    <Border Margin="4" CornerRadius="8" Cursor="Hand"
                            MouseDown="BorderDia_MouseDown"
                            Tag="{Binding}"
                            BorderBrush="{Binding Converter={StaticResource DiaCorBordaConv}}"
                            BorderThickness="{Binding Converter={StaticResource DiaThicknessConv}}">

                        <Border.Background>
                            <MultiBinding Converter="{StaticResource DataTemNotaCorConv}">
                                <Binding Path="."/>
                                <Binding Path="DataContext.DatasComNotas"
                                         RelativeSource="{RelativeSource AncestorType=Page}"/>
                            </MultiBinding>
                        </Border.Background>

                        <!-- Tooltip com texto completo -->
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="{Binding TooltipTexto}" MaxWidth="400" TextWrapping="Wrap"/>
                            </ToolTip>
                        </Border.ToolTip>

                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Número do dia -->
                            <TextBlock Grid.Row="0" Text="{Binding DiaDaString}"
                                       FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EhVazio}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Prévia do conteúdo -->
                            <TextBlock Grid.Row="1" Text="{Binding PreviewTexto}"
                                       FontSize="10" Foreground="#5D6D7E"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       MaxHeight="60" Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EhVazio}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TemNota}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
