<!-- MainView.xaml — v1.3.0 -->
<!-- ALTERAÇÕES:
     1. chartDisciplinas: DataClick conectado ao handler no code-behind
     2. DefaultTooltip adicionado para mostrar nome da disciplina ao passar o mouse
     3. Hint visual "clique em uma fatia para navegar"
     4. Proporção das colunas ajustada: pizza maior (1.4*) e tabela menor (1*)
        para o gráfico de pizza não ficar pequeno demais.
-->
<Page x:Class="RevisaFacil.Views.MainView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Painel Principal" Background="#F4F7F6">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0" Text="Resumo do Desempenho" FontSize="26" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,20"/>

            <!-- Cards de resumo geral -->
            <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="10" Margin="5" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Total de Assuntos" HorizontalAlignment="Center"
                                   Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock x:Name="txtTotalAssuntos" Text="0" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="5" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock x:Name="txtLabelConcluidos" Text="Concluídos (10 Revs)"
                                   HorizontalAlignment="Center" Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock x:Name="txtConcluidos" Text="0" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="5" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Pendentes" HorizontalAlignment="Center"
                                   Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock x:Name="txtPendentes" Text="0" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#E74C3C"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Linha do meio: Gráfico + Tabela por disciplina -->
            <!-- ALTERAÇÃO: Pizza aumentada de 1* para 1.4*, Tabela reduzida de 1.6* para 1* -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Gráfico de Pizza clicável -->
                <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="5"
                        Padding="20" MinHeight="360">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Distribuição por Disciplina"
                                   FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2"/>

                        <!-- Dica de uso -->
                        <TextBlock Grid.Row="1"
                                   Text="💡 Clique em uma fatia para ir à disciplina"
                                   FontSize="10" Foreground="#95A5A6" Margin="0,0,0,8"/>

                        <!--
                            DataClick  → clique simples em qualquer fatia dispara ChartDisciplinas_DataClick
                            Hoverable  → ativa o tooltip automático do LiveCharts
                            DefaultTooltip → mostra nome + valor ao passar o mouse
                        -->
                        <lvc:PieChart x:Name="chartDisciplinas" Grid.Row="2"
                                      LegendLocation="Bottom"
                                      Hoverable="True"
                                      DataClick="ChartDisciplinas_DataClick">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip SelectionMode="OnlySender" BulletSize="10"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>
                    </Grid>
                </Border>

                <!-- Tabela de Estatísticas por Disciplina -->
                <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="5" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Desempenho por Disciplina"
                                   FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" x:Name="dgEstatisticas"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserResizeRows="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" BorderThickness="0"
                                  Background="White" RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  HeadersVisibility="Column" FontSize="12">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F0F3F4"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EBF5FB"/>
                                            <Setter Property="Foreground" Value="#2C3E50"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Disciplina" Binding="{Binding NomeDisciplina}" Width="*"/>
                                <DataGridTextColumn Header="Assuntos"   Binding="{Binding TotalAssuntos}"  Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Taxa" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TaxaConclusaoTexto}"
                                                           Foreground="{Binding CorTaxa}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Background="#F0F3F4"
                                                        CornerRadius="3" Height="8"
                                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                                    <Border Background="{Binding CorTaxa}"
                                                            CornerRadius="3"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding LarguraBarra}"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Atraso Médio" Binding="{Binding AtrasoMedioTexto}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{Binding CorAtraso}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Atrasadas" Binding="{Binding RevisoesAtrasadas}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Card de resumo do dia -->
            <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="20" Margin="5,0,5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="📅 Revisões Hoje" Foreground="#7F8C8D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtRevisoesHoje" Text="0" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#2980B9"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="⏰ Em Atraso" Foreground="#7F8C8D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtRevisoesAtrasadas" Text="0" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#E74C3C"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="✅ Concluídas Hoje" Foreground="#7F8C8D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtConcluidasHoje" Text="0" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#27AE60"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
