<Page x:Class="RevisaFacil.Views.NovoAssuntoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Novo Assunto" Background="#F0F3F4">

    <Grid Margin="30">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock Text="CADASTRAR NOVO ASSUNTO" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20" 
                       Foreground="#2C3E50"/>

            <Border Background="White" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Selecione a Disciplina:" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,5" 
                               Foreground="#34495E"/>

                    <ComboBox x:Name="cbDisciplina" 
                              Height="35" 
                              Margin="0,0,0,15" 
                              VerticalContentAlignment="Center"/>

                    <TextBlock Text="Título do Assunto:" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,5" 
                               Foreground="#34495E"/>

                    <TextBox x:Name="txtTitulo" 
                             Height="35" 
                             Margin="0,0,0,25" 
                             VerticalContentAlignment="Center" 
                             Padding="5,0"/>

                    <Button Content="Salvar Assunto" 
                            Click="btnSalvar_Click" 
                            IsDefault="True"
                            Background="#27AE60" 
                            Foreground="White" 
                            Height="45" 
                            FontWeight="Bold" 
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Text="* Os intervalos de revisão padrão (1, 7, 15, 30, 60, 90 dias) serão aplicados automaticamente." 
                       Margin="0,15,0,0" 
                       Foreground="#7F8C8D" 
                       FontSize="11" 
                       FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</Page>