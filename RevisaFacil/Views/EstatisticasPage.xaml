<!-- EstatisticasPage.xaml -->
<Page x:Class="RevisaFacil.Views.EstatisticasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Estatísticas" Background="#F0F3F4">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="📊 ESTATÍSTICAS DE DESEMPENHO"
                   FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Cards de resumo rápido -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,15">
            <!-- Muito estudados -->
            <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="✅ Muito Revisados" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtMuitoEstudados" Text="0" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#27AE60"/>
                    <TextBlock Text="≥ 70% revisões concluídas" FontSize="10" Foreground="#95A5A6"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- Moderados -->
            <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="⚠️ Em Progresso" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtModerados" Text="0" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#F39C12"/>
                    <TextBlock Text="30% a 69% concluídas" FontSize="10" Foreground="#95A5A6"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- Pouco estudados -->
            <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🔴 Pouco Revisados" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtPoucoEstudados" Text="0" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#E74C3C"/>
                    <TextBlock Text="abaixo de 30% concluídas" FontSize="10" Foreground="#95A5A6"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- Iniciados (destacados) -->
            <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🟢 Iniciados (Destacados)" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtIniciados" Text="0" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#2980B9"/>
                    <TextBlock Text="assuntos marcados em verde" FontSize="10" Foreground="#95A5A6"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Filtros -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtrar por:" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,15,0" Foreground="#34495E"/>
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Disciplina:" FontSize="11" Foreground="#7F8C8D"/>
                    <ComboBox x:Name="cbFiltroDisciplina" Width="180" DisplayMemberPath="Nome"
                              SelectedValuePath="Id" SelectionChanged="Filtro_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Desempenho:" FontSize="11" Foreground="#7F8C8D"/>
                    <ComboBox x:Name="cbFiltroDesempenho" Width="160" SelectionChanged="Filtro_Changed">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                        <ComboBoxItem Content="✅ Muito revisados (≥70%)"/>
                        <ComboBoxItem Content="⚠️ Em progresso (30-69%)"/>
                        <ComboBoxItem Content="🔴 Pouco revisados (&lt;30%)"/>
                        <ComboBoxItem Content="🟢 Iniciados (Destacados)"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Buscar assunto:" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtBusca" Width="180" TextChanged="Filtro_Changed"/>
                </StackPanel>
                <Button Content="Limpar" Click="LimparFiltros_Click" VerticalAlignment="Bottom"
                        Height="26" Padding="10,0" Background="#95A5A6" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Tabela de estatísticas por assunto -->
        <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Detalhamento por Assunto" FontWeight="SemiBold"
                           Foreground="#34495E" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" x:Name="dgEstatisticasAssuntos"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          HeadersVisibility="Column"
                          FontSize="12">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F3F4"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDestacado}" Value="True">
                                    <Setter Property="Background" Value="#D4EFDF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Status" Binding="{Binding IconeStatus}" Width="50">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="16"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Disciplina" Binding="{Binding NomeDisciplina}" Width="140"/>
                        <DataGridTextColumn Header="Assunto" Binding="{Binding Titulo}" Width="*"/>

                        <DataGridTextColumn Header="Iniciado em" Binding="{Binding DataInicio, StringFormat=\{0:dd/MM/yyyy\}}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Barra de progresso de conclusão -->
                        <DataGridTemplateColumn Header="Progresso" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding TaxaTexto}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CorTaxa}"
                                                   HorizontalAlignment="Center"
                                                   FontSize="11"/>
                                        <Border Grid.Row="1" Background="#ECF0F1"
                                                CornerRadius="3" Height="6" Margin="0,2,0,0">
                                            <Border Background="{Binding CorTaxa}"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding LarguraBarra}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Rev. Concluídas" Binding="{Binding RevisoesConcluidas}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Rev. Pendentes" Binding="{Binding RevisoesPendentes}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Atraso (dias)" Binding="{Binding AtrasoMaxTexto}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{Binding CorAtraso}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
