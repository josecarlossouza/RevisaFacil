<Page x:Class="RevisaFacil.Views.NovaDisciplinaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Nova Disciplina" Background="White">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" MaxWidth="400" HorizontalAlignment="Left" Margin="0,0,0,30">
            <TextBlock Text="CADASTRAR DISCIPLINA" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Nome da Disciplina:"/>
            <TextBox x:Name="txtNomeDisciplina" Margin="0,5,0,20" Height="30" VerticalContentAlignment="Center"/>
            <Button Content="Salvar Disciplina" IsDefault="True" Click="btnSalvar_Click" 
                    Background="#27AE60" Foreground="White" Height="40" FontWeight="Bold"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Disciplinas Cadastradas" Padding="10">
            <DataGrid x:Name="dgDisciplinas" AutoGenerateColumns="False" CanUserAddRows="False" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome da Disciplina" Binding="{Binding Nome}" Width="*"/>
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Excluir" Click="btnApagarDisciplina_Click" 
                                        Background="#C0392B" Foreground="White" FontWeight="Bold" Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Page>