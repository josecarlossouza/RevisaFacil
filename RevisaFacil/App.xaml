<Application x:Class="RevisaFacil.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:RevisaFacil.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Estilos ──────────────────────────────────────────────────────── -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Converters — TODOS devem estar aqui para o CalendarioPage encontrar ── -->
        <helpers:StatusToColorConverter       x:Key="StatusToColorConverter"/>
        <helpers:DataTemNotaParaCorConverter  x:Key="DataTemNotaParaCorConverter"/>
        <helpers:DiaParaThicknessConverter    x:Key="DiaParaThicknessConverter"/>
        <helpers:DiaParaCorBordaConverter     x:Key="DiaParaCorBordaConverter"/>

    </Application.Resources>
</Application>
